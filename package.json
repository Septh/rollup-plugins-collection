{
  "name": "@septh/rollup-plugins-collection",
  "version": "1.1.0-dev.0",
  "description": "A collection of tiny useful plugins for your everyday Rollup.",
  "keywords": [
    "rollup",
    "plugin",
    "multi"
  ],
  "author": "Stephan 'Septh' Schreiber <septh@sfr.fr>",
  "homepage": "https://github.com/septh/plugins-collection#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/septh/plugins-collection"
  },
  "bugs": "https://github.com/septh/plugins-collection/issues",
  "license": "MIT",
  "funding": [
    {
      "type": "patreon",
      "url": "https://patreon.com/Septh"
    },
    {
      "type": "paypal",
      "url": "https://paypal.me/septh07"
    }
  ],
  "engines": {
    "node": ">= 22"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./enums": {
      "types": "./dist/enums.d.ts",
      "default": "./dist/enums.js"
    },
    "./no-comment": {
      "types": "./dist/no-comment.d.ts",
      "default": "./dist/no-comment.js"
    },
    "./production": {
      "types": "./dist/production.d.ts",
      "default": "./dist/production.js"
    }
  },
  "imports": {
    "#package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "!*.map"
  ],
  "scripts": {
    "prebuild": "npm run clean",
    "build": "npm run build:js && npm run build:dts",
    "build:js": "tsc -p tsconfig.build.json --removeComments",
    "build:dts": "tsc -p tsconfig.build.json --declaration --emitDeclarationOnly --removeComments false",
    "clean": "rimraf dist out",
    "pretest": "npm run build",
    "test": "npm run testOnly",
    "testOnly": "echo \"No test yet",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "estree-walker": "^3.0.3",
    "magic-string": "^0.30.21",
    "regex": "^6.1.0"
  },
  "peerDependencies": {
    "rollup": "^4.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.9",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@septh/ts-run": "^2.0.2",
    "@types/node": "^24.12.0",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.0",
    "rollup-plugin-node-externals": "^8.1.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  }
}
